{:meta {:name "Manimani Experience UI"
        :version "0.1.0"
        :model {:foundation 0.70 :companion 0.20 :reward 0.10}}
 :size {:tap-target-min 44
        :text-min 16
        :content-max 1120
        :radius-control 12
        :radius-card 20}
 :space {:1 4 :2 8 :3 12 :4 16 :5 24 :6 32 :7 48}
 :type {:family {:jp "Noto Sans JP"
                 :fallback "-apple-system, BlinkMacSystemFont, sans-serif"}
        :body {:size 16 :line-height 1.5}
        :label {:size 13 :line-height 1.3 :weight 600}
        :title {:size 28 :line-height 1.15 :weight 700}
        :mono {:family "ui-monospace, SFMono-Regular, Menlo, monospace"}}
 :color {:canvas "#F7F8F5"
         :surface "#FFFFFF"
         :ink "#17201B"
         :muted "#637069"
         :line "#D8DED9"
         :accent "#F2B84B"
         :accent-ink "#2D2108"
         :info "#246FC7"
         :success "#23845B"
         :warning "#B86B00"
         :danger "#B83232"
         :private "#7A4CC2"}
 :state {:visibility [:public :internal :private]
         :capability [:read :triage :write :maintain :admin]
         :sensitivity [:public :internal :confidential :privileged]
         :run [:queued :running :external-wait :blocked :needs-approval :failed :verified]}}
