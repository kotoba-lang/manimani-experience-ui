{:meta {:name "Manimani Loom"
        :version "0.1.0"
        :purpose "Parallel agent-loop topology and presentation contract"
        :terms {:loom "並列loop全体"
                :trail "個々のagent loop経路"
                :receipt-back-walk "receiptから必要条件を逆向きに展開する計画"
                :forward-walk "依存関係を満たしてsourceからreceiptへ進む実行"}}

 :shell
 {:chat {:primary-agent :manimani/orchestrator
         :layers [:conversation :running-summary :loom]
         :summary-order [:blocked :needs-approval :running :external-wait :queued :verified]
         :summary-example {:running 12 :waiting 3 :blocked 1}
         :mobile {:default :summary
                  :expand :clustered-loom
                  :cluster-by [:system :repo :state]
                  :max-simultaneous-mascots 4
                  :max-visible-agent-glyphs 30}
         :desktop {:default :summary-with-critical-path
                   :max-simultaneous-mascots 8
                   :max-visible-agent-glyphs 60}
         :offscreen-animation :paused
         :exit-paths [:header-back :system-back]}}

 :density
 {:semantic-zoom
  {:z0 {:name :summary
        :shows [:total :running :waiting :blocked]
        :agent-representation :none}
   :z1 {:name :cluster
        :shows [:system :repo-count :state-count :critical-path]
        :agent-representation :five-dot-wheel
        :agents-per-cluster 5}
   :z2 {:name :trail-grid
        :shows [:agent :loop :repo :state :progress]
        :agent-representation :compact-glyph
        :row-height 32
        :glyph-size 18}
   :z3 {:name :focused-agent
        :shows [:full-mascot :evidence :authority :dependencies :controls]
        :agent-representation :kinetic-companion}}
  :adaptive-breakpoints
  [{:max-agents 8 :default-zoom :z2 :columns 1}
   {:max-agents 20 :default-zoom :z1 :columns 2}
   {:max-agents 40 :default-zoom :z1 :columns 3}
   {:max-agents :unbounded :default-zoom :z0 :virtualized true}]
  :animation-budget {:max-mobile 4
                     :max-desktop 8
                     :priority [:blocked :critical-path :selected :needs-approval :running]
                     :others :static-state-glyph}
  :ordering [:blocked-first :critical-path :needs-approval :running :waiting :queued]
  :virtualization {:threshold 40 :overscan-rows 2}}

 :focused-agent-chat
 {:entry [:agent-glyph :trail-grid-row :blocker-card :critical-path-node]
  :route {:pattern "/chat/agents/:agent-id"
          :preserve [:loom-filter :scroll-position :selected-loop]
          :back-destination :loom}
  :header {:required [:agent-id :loop-label :org :repo :authority :state]
           :sticky true
           :authority-not-color-only true}
  :transcript
  {:parts [:user-message :agent-message :reasoning-summary :plan
           :tool-call :command :command-output :code :diff
           :evidence :approval-preview :receipt]
   :chronological true
   :tool-default :collapsed
   :running-tool-expanded true
   :failed-tool-expanded true
   :line-wrap {:prose true :code false :output :user-toggle}
   :code {:font-family :ui-monospace
          :line-numbers true
          :copy true
          :open-file true
          :horizontal-scroll true
          :max-default-lines 18
          :expand-label "全文を表示"}
   :diff {:modes [:unified :split]
          :default-mobile :unified
          :default-desktop :split
          :context-lines 3
          :syntax-highlight true}}
  :composer {:tab-bar :hidden
             :attachments [:context :file :image]
             :actions [:send :interrupt :approve-preview]
             :safe-area-fixed true}
  :desktop {:layout :conversation-and-artifact
            :conversation-ratio 0.42
            :artifact-ratio 0.58}
  :mobile {:layout :single-column
           :artifact-presentation :inline-expandable}
  :safety {:external-write :preview-required
           :command-shows [:cwd :command :exit-code :duration]
           :secrets :redacted
           :private-code :no-notification-preview}}

 :topology
 {:kind :dependency-dag
  :planning {:direction :reverse-topological
             :name :receipt-back-walk
             :from :verified-receipt
             :toward :observed-signal
             :purpose :derive-required-evidence}
  :execution {:direction :topological
              :name :forward-walk
              :from :observed-signal
              :toward :verified-receipt
              :purpose :satisfy-dependencies-safely}
  :canonical-path [:observed-signal
                   :framed-issue
                   :accepted-change
                   :pull-request
                   :passing-actions
                   :approval
                   :verified-receipt]
  :presentation {:planning-lane :upper
                 :execution-lane :lower
                 :intersection :current-leverage-point
                 :edge-labels [:requires :produces :blocks]
                 :direction-not-color-only true}}

 :scheduler
 {:ready-when [:dependencies-verified
               :authority-available
               :concurrency-slot-available
               :no-unresolved-blocker]
  :pools {:observation 8
          :code-write 4
          :ci 4
          :external-write :approved-only}
  :limits {:global-running 20
           :default-running 10
           :repo-write-agents 1
           :private-context :explicitly-authorized-only}
  :backpressure {:high-watermark 16
                 :action :stop-admitting-noncritical-work
                 :resume-watermark 10}
  :priority {:formula :critical-path-age-risk
             :factors {:critical-path 0.40
                       :blocker-age 0.25
                       :receipt-value 0.20
                       :risk-inverse 0.15}}
  :write-conflict {:strategy :single-writer-per-repo
                   :on-conflict :queue-and-surface}}

 :agent
 {:required-keys [:loop/id :agent/id :context :depends-on :produces
                  :state :authority :progress :blocker :receipt]
  :states [:queued :running :dependency-wait :external-wait
           :blocked :needs-approval :failed :verified :paused]
  :example {:loop/id :mail-to-issue
            :agent/id :manimani/mail-01
            :context {:org :kotoba-lang :repo :shell}
            :depends-on #{:mail-fetch :identity-resolution}
            :produces #{:issue-proposal}
            :state :running
            :authority :read-only
            :progress {:verified 3 :total 5}
            :blocker nil
            :receipt nil}}

 :loops
 {:mail-to-issue
  {:label "メール取得まにまに君"
   :kind :observation
   :authority-default :read-only
   :steps [:fetch :normalize :classify :link-context
           :deduplicate :propose-issue :policy-check :create-issue :learn]
   :incremental {:cursor-required true :idempotency-key-required true}
   :privacy {:body-retention :local
             :github-output :redacted-summary
             :attachments :restricted-context
             :secrets :never-export}
   :gates {:create-issue [:repo-resolved :visibility-known :actor-known
                          :evidence-linked :duplicate-check-passed
                          :policy-authorized]}}

  :design {:label "Designまにまに君"
           :kind :change
           :steps [:observe :frame :prototype :verify :learn]}
  :bmc {:label "BMCまにまに君"
        :kind :model
        :steps [:observe :hypothesize :model :check :revise]}
  :code {:label "Codeまにまに君"
         :kind :code-write
         :steps [:inspect :plan :change :test :propose-pr]}
  :ci {:label "CIまにまに君"
       :kind :ci
       :steps [:dispatch :observe :classify :retry-or-escalate :receipt]}
  :review {:label "Reviewまにまに君"
           :kind :verification
           :steps [:read-intent :inspect-diff :check-evidence :decide]}}

 :visual-state
 {:running {:mascot :run-in-wheel :speed :work-rate}
  :queued {:mascot :sit-and-watch-wheel :speed 0}
  :dependency-wait {:mascot :look-forward :wheel :coast}
  :external-wait {:mascot :listen :wheel :base-speed}
  :blocked {:mascot :slow-before-obstacle :wheel :decelerate}
  :needs-approval {:mascot :face-user :wheel :base-speed}
  :verified {:mascot :carry-receipt :celebration :once}
  :failed {:mascot :inspect-and-recover :punishment false}
  :paused {:mascot :rest :wheel :stopped}
  :constraints {:state-not-animation-only true
                :direction-not-color-only true
                :reduced-motion-equivalent true
                :no-fake-progress-from-play-input true}}

 :telemetry
 {:measures [:five-second-state-accuracy
             :agent-find-time
             :agent-repo-confusion-rate
             :dependency-direction-error-rate
             :blocker-owner-find-time
             :critical-path-discovery-rate
             :reduced-motion-state-parity
             :animation-frame-time
             :write-conflict-count
             :false-completion-count]
  :critical-gates {:false-completion {:max 0}
                   :unknown-write-authority {:max 0}
                   :repo-write-conflict {:max 0}
                   :private-context-leak {:max 0}}
  :target {:five-second-state-accuracy {:min 0.90}
           :agent-repo-confusion-rate {:max 0.02}
           :dependency-direction-error-rate {:max 0.05}
           :animation-frame-time-p95-ms {:max 16.7}}}}
