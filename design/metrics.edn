{:meta {:name "MEUI quality model" :version "0.1.0" :range [0 1]}
 :weights {:perceptual 0.16
           :interaction 0.14
           :observability 0.20
           :accessibility 0.18
           :trust-calibration 0.16
           :loop-outcome 0.12
           :companion-quality 0.04}
 :measures
 {:perceptual [:contrast-pass-rate :text-overflow-pass-rate :hierarchy-five-second-accuracy]
  :interaction [:task-completion :target-error-rate :input-ack-latency :predicted-fitts-time
                :keyboard-occlusion-rate :composer-reachability :accidental-tab-activation-rate]
  :observability [:context-accuracy :state-accuracy :next-action-accuracy :risk-accuracy]
  :accessibility [:keyboard-completion :screen-reader-completion :zoom-completion :reduced-motion-parity]
  :trust-calibration [:appropriate-reliance :one-minus-brier :scope-comprehension :undo-availability]
  :loop-outcome [:verified-throughput :one-minus-rework-rate :blocker-release-rate :learning-gain]
  :companion-quality [:motion-frame-stability :settling-quality :semantic-differential
                      :five-second-state-accuracy :agent-find-time
                      :agent-repo-confusion-rate :dependency-direction-error-rate
                      :critical-path-discovery-rate]}
 :critical-gates
 {:false-done {:max 0}
  :visibility-capability-confusion {:max 0}
  :unpreviewed-external-write {:max 0}
  :inaccessible-core-journey {:max 0}
  :reduced-motion-state-loss {:max 0}}
 :chat-gates {:composer-occluded-by-keyboard {:max 0}
              :no-keyboard-dismiss-path {:max 0}
              :no-chat-exit-path {:max 0}
              :repo-write-conflict {:max 0}
              :private-context-leak {:max 0}}
 :report {:composite :weighted-mean
          :critical-gates :non-compensatory
          :uncertainty :confidence-interval-95
          :segments [:novice :experienced :mobile :desktop :assistive-technology]}}
